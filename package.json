{
  "name": "portfolio-web-components",
  "version": "1.0.0",
  "description": "Portfolio website built with Lion Web Components",
  "type": "module",
  "scripts": {
    "start": "web-dev-server --node-resolve --open --watch",
    "build": "rollup -c",
    "preview": "npm run build && web-dev-server --root-dir dist --app-index index.html --open",
    "test": "web-test-runner \"src/**/*.test.js\" --node-resolve"
  },
  "dependencies": {
    "dompurify": "^3.4.10",
    "lit": "^3.3.3",
    "marked": "^18.0.5"
  },
  "devDependencies": {
    "@open-wc/testing": "^4.0.0",
    "@rollup/plugin-html": "^2.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@web/dev-server": "^0.4.6",
    "@web/test-runner": "^0.20.2",
    "rollup": "^4.62.0",
    "rollup-plugin-copy": "^3.5.0"
  }
}
